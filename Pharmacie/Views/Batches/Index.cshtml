@model BatchIndexPageViewModel
@{
    ViewData["Title"] = "Lots (péremption)";
    var horizon = AlertsIndexViewModel.ExpirationHorizonDays;
}

<div class="page-header">
    <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-lg-between gap-3">
        <div>
            <h1 class="page-title">Lots</h1>
            <p class="page-lead mb-0">Traçabilité par numéro de lot et date d’expiration.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouvelle entrée (lot)</a>
            <a class="btn btn-outline-secondary" asp-controller="StockMovements" asp-action="Index"><i class="bi bi-list-ul me-1" aria-hidden="true"></i>Mouvements</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3">Filtres</h2>
        <p class="small text-muted mb-3">
            <strong>Produit</strong> : lots de ce produit uniquement. <strong>N° de lot</strong> : texte contenu dans le numéro (recherche partielle).
            <strong>Péremption</strong> : « Proche » = date entre aujourd’hui et +@horizon jours (même fenêtre que les alertes), quantité restante &gt; 0 ; « Expiré » = date avant aujourd’hui avec stock restant &gt; 0.
        </p>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="ProductId">Produit</label>
                <select name="ProductId" id="ProductId" class="form-select form-select-sm">
                    @if ((Model.Filter.ProductId ?? 0) > 0)
                    {
                        <option value="">Tous</option>
                    }
                    else
                    {
                        <option value="" selected>Tous</option>
                    }
                    @foreach (var p in Model.ProductLookup)
                    {
                        if (Model.Filter.ProductId == p.Id)
                        {
                            <option value="@p.Id" selected>@p.CommercialName</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.CommercialName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="Lot">N° de lot (contient)</label>
                <input type="search" name="Lot" id="Lot" value="@Model.Filter.Lot" class="form-control form-control-sm" autocomplete="off" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="Expiration">Péremption</label>
                <select name="Expiration" id="Expiration" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.Expiration))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (Model.Filter.Expiration == "near")
                    {
                        <option value="near" selected>Proche (@horizon j.)</option>
                    }
                    else
                    {
                        <option value="near">Proche (@horizon j.)</option>
                    }
                    @if (Model.Filter.Expiration == "expired")
                    {
                        <option value="expired" selected>Expiré (stock &gt; 0)</option>
                    }
                    else
                    {
                        <option value="expired">Expiré (stock &gt; 0)</option>
                    }
                </select>
            </div>
            <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 pt-1 pt-lg-0">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
            </div>
        </form>
    </div>
</div>

@if ((int)(ViewBag.ProvisionalCount ?? 0) > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
        <span>
            <strong>@ViewBag.ProvisionalCount lot(s)</strong>
            ont une date d'expiration provisoire à corriger.
        </span>
        @if (!(bool)(ViewBag.ProvisionalOnly ?? false))
        {
            <a asp-action="Index" asp-route-provisionalOnly="true"
               class="btn btn-warning btn-sm ms-auto">
                <i class="bi bi-funnel" aria-hidden="true"></i> Voir ces lots
            </a>
        }
        else
        {
            <a asp-action="Index"
               class="btn btn-outline-secondary btn-sm ms-auto">
                <i class="bi bi-x-circle" aria-hidden="true"></i> Voir tous les lots
            </a>
        }
    </div>
}

<div class="table-card mb-3">
    <div class="table-responsive">
        <table class="table table-striped table-sm mb-0">
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>N° de lot</th>
                    <th>Date d'expiration</th>
                    <th>Quantité restante</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Batches)
                {
                    <tr>
                        <td>@item.Product?.CommercialName</td>
                        <td>@Html.DisplayFor(m => item.LotNumber)</td>
                        <td>
                            @item.ExpirationDate.ToString("yyyy-MM-dd")
                            @if (item.SourceImportLineId != null)
                            {
                                <span class="badge bg-warning-subtle text-warning ms-1"
                                      title="Date provisoire — à corriger">
                                    <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> Provisoire
                                </span>
                            }
                        </td>
                        <td>@Html.DisplayFor(m => item.Quantity)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary py-0" asp-action="Details" asp-route-id="@item.Id">Détails</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Batches.Count > 0)
    {
        <div class="table-card-caption d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 px-3 py-2">
            <span>@Model.Batches.Count lot(s) sur @(ViewBag.TotalCount ?? 0) · page @(ViewBag.CurrentPage ?? 1)/@(ViewBag.TotalPages ?? 1)</span>
            @{
                var paginationRoutes = new Dictionary<string, string>();
                if (Model.Filter.ProductId is > 0)
                    paginationRoutes["ProductId"] = Model.Filter.ProductId.Value.ToString();
                if (!string.IsNullOrWhiteSpace(Model.Filter.Lot))
                    paginationRoutes["Lot"] = Model.Filter.Lot;
                if (!string.IsNullOrWhiteSpace(Model.Filter.Expiration))
                    paginationRoutes["Expiration"] = Model.Filter.Expiration;
                if ((bool)(ViewBag.ProvisionalOnly ?? false))
                    paginationRoutes["provisionalOnly"] = "true";
                ViewBag.PaginationRoutes = paginationRoutes;
            }
            <partial name="_Pagination" />
        </div>
    }
</div>
@if (Model.Batches.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-layers" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun lot</p>
        <p class="mb-0 small">Aucun résultat pour ces critères.</p>
    </div>
}
