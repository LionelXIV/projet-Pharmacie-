<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Pharmacie</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_blue.min.css" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Pharmacie.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var routeController = (ViewContext.RouteData.Values["controller"] as string) ?? string.Empty;
    var routeAction = (ViewContext.RouteData.Values["action"] as string) ?? string.Empty;
    bool IsCtrl(string name) => string.Equals(routeController, name, StringComparison.OrdinalIgnoreCase);
    bool IsAction(string name) => string.Equals(routeAction, name, StringComparison.OrdinalIgnoreCase);
    bool IsCtrlAny(params string[] names) => names.Any(n => string.Equals(routeController, n, StringComparison.OrdinalIgnoreCase));
    var isHome = IsCtrl("Home");
    var isDashboard = IsCtrl("Dashboard");
    var isReports = IsCtrl("Reports");
    var isCatalog = IsCtrlAny("Products", "Batches", "StockMovements", "ProductImports");
    var isPurchasing = IsCtrlAny("PurchaseOrders", "Categories", "Suppliers", "GoodsReceipts");
    var isSales = IsCtrl("Sales");
    var isCommerce = isSales || isPurchasing;
    var isPatients = IsCtrlAny("Patients", "PatientPrescriptions", "PatientReminders", "PatientRemindersAlerts");
    var isAlerts = IsCtrl("Alerts");
    var isAdminUsers = IsCtrl("AdminUsers");
    var showPrincipalSection = true;
    var showCatalogueSection = true;
    var showStockSection = true;
    var showCommerceSection = User?.Identity?.IsAuthenticated == true && AppRoles.CanSeeCommerceMenu(User);
    var showPatientsSection = User?.Identity?.IsAuthenticated == true && AppRoles.CanAccessPatientsRead(User);
    var showDonneesSection = User?.Identity?.IsAuthenticated == true && AppRoles.CanAccessDashboard(User);
    var showAdminSection = User?.Identity?.IsAuthenticated == true && User.IsInRole(AppRoles.Administrateur);
}
<body>
    <a class="skip-link visually-hidden-focusable" href="#main-content">Aller au contenu</a>
    <div class="ph-app">
        <aside class="ph-sidebar" id="sidebar" aria-label="Navigation principale">
            <a class="ph-sidebar-brand text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-mark" aria-hidden="true">
                    <svg class="brand-mark-svg" width="32" height="32" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
                        <title>Pharmacie</title>
                        <rect x="2" y="2" width="40" height="40" rx="11" fill="#2563EB"/>
                        <path d="M20 11h4v9h9v4h-9v9h-4v-9h-9v-4h9v-9z" fill="#fff"/>
                    </svg>
                </span>
                <span>Pharmacie</span>
            </a>

            <nav class="ph-sidebar-nav">
                @if (showPrincipalSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Principal</span>
                        <a class="nav-link @(isHome ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Index" aria-current="@(isHome ? "page" : null)">
                            <i class="bi bi-house-door" aria-hidden="true"></i>Accueil
                        </a>
                        @if (User?.Identity?.IsAuthenticated == true && AppRoles.CanAccessDashboard(User))
                        {
                            <a class="nav-link @(isDashboard ? "active" : null)" asp-controller="Dashboard" asp-action="Index" aria-current="@(isDashboard ? "page" : null)">
                                <i class="bi bi-speedometer2" aria-hidden="true"></i>Tableau de bord
                            </a>
                        }
                        <a class="nav-link @(isAlerts ? "active" : null)" asp-controller="Alerts" asp-action="Index" aria-current="@(isAlerts ? "page" : null)">
                            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>Alertes
                        </a>
                    </div>
                }

                @if (showCatalogueSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Catalogue</span>
                        <a class="nav-link @(IsCtrl("Products") ? "active" : null)" asp-controller="Products" asp-action="Index" aria-current="@(IsCtrl("Products") ? "page" : null)">
                            <i class="bi bi-capsule" aria-hidden="true"></i>Produits
                        </a>
                        @if (User?.Identity?.IsAuthenticated == true && AppRoles.CanAccessCatalog(User))
                        {
                            <a class="nav-link @(IsCtrl("Categories") ? "active" : null)" asp-controller="Categories" asp-action="Index" aria-current="@(IsCtrl("Categories") ? "page" : null)">
                                <i class="bi bi-bookmark" aria-hidden="true"></i>Catégories
                            </a>
                            <a class="nav-link @(IsCtrl("Suppliers") ? "active" : null)" asp-controller="Suppliers" asp-action="Index" aria-current="@(IsCtrl("Suppliers") ? "page" : null)">
                                <i class="bi bi-building" aria-hidden="true"></i>Fournisseurs
                            </a>
                        }
                        @if (User?.Identity?.IsAuthenticated == true && (User.IsInRole(AppRoles.Administrateur) || User.IsInRole(AppRoles.Pharmacien)))
                        {
                            <a class="nav-link @(IsCtrl("ProductImports") ? "active" : null)" asp-controller="ProductImports" asp-action="Upload" aria-current="@(IsCtrl("ProductImports") ? "page" : null)">
                                <i class="bi bi-file-earmark-spreadsheet" aria-hidden="true"></i>Import produits
                            </a>
                        }
                    </div>
                }

                @if (showStockSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Stock</span>
                        <a class="nav-link @(IsCtrl("Batches") ? "active" : null)" asp-controller="Batches" asp-action="Index" aria-current="@(IsCtrl("Batches") ? "page" : null)">
                            <i class="bi bi-layers" aria-hidden="true"></i>Lots
                        </a>
                        <a class="nav-link @(IsCtrl("StockMovements") ? "active" : null)" asp-controller="StockMovements" asp-action="Index" aria-current="@(IsCtrl("StockMovements") ? "page" : null)">
                            <i class="bi bi-arrow-down-up" aria-hidden="true"></i>Mouvements
                        </a>
                    </div>
                }

                @if (showCommerceSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Commerce</span>
                        @if (AppRoles.CanAccessSales(User!))
                        {
                            <a class="nav-link @(isSales ? "active" : null)" asp-controller="Sales" asp-action="Index" aria-current="@(isSales ? "page" : null)">
                                <i class="bi bi-cash-register" aria-hidden="true"></i>Ventes
                            </a>
                        }
                        @if (AppRoles.CanAccessPurchasing(User!))
                        {
                            <a class="nav-link @(IsCtrl("PurchaseOrders") ? "active" : null)" asp-controller="PurchaseOrders" asp-action="Index" aria-current="@(IsCtrl("PurchaseOrders") ? "page" : null)">
                                <i class="bi bi-bag-check" aria-hidden="true"></i>Commandes fournisseurs
                            </a>
                        }
                    </div>
                }

                @if (showPatientsSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Patients</span>
                        <a class="nav-link @(IsCtrl("Patients") ? "active" : null)" asp-controller="Patients" asp-action="Index" aria-current="@(IsCtrl("Patients") ? "page" : null)">
                            <i class="bi bi-person-lines-fill" aria-hidden="true"></i>Portefeuille
                        </a>
                        <a class="nav-link @(IsCtrl("PatientRemindersAlerts") ? "active" : null)" asp-controller="PatientRemindersAlerts" asp-action="Index" aria-current="@(IsCtrl("PatientRemindersAlerts") ? "page" : null)">
                            <i class="bi bi-alarm" aria-hidden="true"></i>Rappels à traiter
                        </a>
                    </div>
                }

                @if (showDonneesSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Données</span>
                        <a class="nav-link @(isReports && IsAction("Index") ? "active" : null)" asp-controller="Reports" asp-action="Index" aria-current="@(isReports && IsAction("Index") ? "page" : null)">
                            <i class="bi bi-columns-gap" aria-hidden="true"></i>Vue d'ensemble
                        </a>
                        <a class="nav-link @(isReports && IsAction("StockStatus") ? "active" : null)" asp-controller="Reports" asp-action="StockStatus" aria-current="@(isReports && IsAction("StockStatus") ? "page" : null)">
                            <i class="bi bi-clipboard-data" aria-hidden="true"></i>État du stock
                        </a>
                        <a class="nav-link @(isReports && IsAction("NearExpiration") ? "active" : null)" asp-controller="Reports" asp-action="NearExpiration" aria-current="@(isReports && IsAction("NearExpiration") ? "page" : null)">
                            <i class="bi bi-hourglass-split" aria-hidden="true"></i>Proches expiration
                        </a>
                        <a class="nav-link @(isReports && IsAction("ExpiredProducts") ? "active" : null)" asp-controller="Reports" asp-action="ExpiredProducts" aria-current="@(isReports && IsAction("ExpiredProducts") ? "page" : null)">
                            <i class="bi bi-calendar-x" aria-hidden="true"></i>Produits expirés
                        </a>
                        <a class="nav-link @(isReports && IsAction("SalesHistory") ? "active" : null)" asp-controller="Reports" asp-action="SalesHistory" aria-current="@(isReports && IsAction("SalesHistory") ? "page" : null)">
                            <i class="bi bi-receipt" aria-hidden="true"></i>Historique ventes
                        </a>
                        <a class="nav-link @(isReports && IsAction("StockMovementsHistory") ? "active" : null)" asp-controller="Reports" asp-action="StockMovementsHistory" aria-current="@(isReports && IsAction("StockMovementsHistory") ? "page" : null)">
                            <i class="bi bi-arrow-left-right" aria-hidden="true"></i>Historique mouvements
                        </a>
                    </div>
                }

                @if (showAdminSection)
                {
                    <div class="ph-nav-section">
                        <span class="ph-nav-label">Administration</span>
                        <a class="nav-link @(isAdminUsers ? "active" : null)" asp-controller="AdminUsers" asp-action="Index" aria-current="@(isAdminUsers ? "page" : null)">
                            <i class="bi bi-person-gear" aria-hidden="true"></i>Utilisateurs
                        </a>
                    </div>
                }
            </nav>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="ph-sidebar-user">
                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                    <span class="text-truncate">@User.Identity?.Name</span>
                </div>
            }
        </aside>

        <div class="ph-sidebar-overlay d-lg-none"
             id="sidebarOverlay"
             aria-hidden="true"></div>

        <div class="ph-main">
            <header class="ph-topbar">
                <button class="ph-burger btn btn-link p-0 me-3 d-lg-none"
                        type="button"
                        id="sidebarToggleMobile"
                        aria-label="Ouvrir le menu"
                        aria-expanded="false">
                    <i class="bi bi-list fs-3 text-dark" aria-hidden="true"></i>
                </button>
                <h6 class="ph-page-title mb-0">@ViewData["Title"]</h6>
                <span class="ph-mobile-nav-hint text-muted small">Menu latéral sur grand écran</span>
                <div class="ph-topbar-actions">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main id="main-content" role="main" class="ph-content-wrapper" tabindex="-1">
                <div class="app-flash-stack mb-3">
                    <partial name="_FlashMessages" />
                </div>
                @RenderBody()
            </main>

            <footer class="app-footer">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 px-3 px-md-4 py-3">
                    <span>&copy; 2026 — Pharmacie</span>
                    <span><a asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a></span>
                </div>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
      if (window.toastr) {
        toastr.options = {
          closeButton: true,
          progressBar: true,
          positionClass: "toast-top-right",
          timeOut: 4000,
          extendedTimeOut: 1000
        };
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js" crossorigin="anonymous"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.addEventListener('click', function (e) {
          const btn = e.target.closest('[data-confirm]');
          if (!btn) return;

          const form = btn.closest('form');
          if (!form) return;

          e.preventDefault();

          const message = btn.dataset.confirm || 'Cette action est irréversible.';

          if (!window.Swal) {
            if (confirm(message)) {
              if (form.requestSubmit) {
                form.requestSubmit(btn);
              } else {
                form.submit();
              }
            }
            return;
          }

          Swal.fire({
            title: 'Confirmer',
            text: message,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#EF4444',
            cancelButtonColor: '#64748B',
            confirmButtonText: 'Confirmer',
            cancelButtonText: 'Annuler'
          }).then((result) => {
            if (result.isConfirmed) {
              if (form.requestSubmit) {
                form.requestSubmit(btn);
              } else {
                form.submit();
              }
            }
          });
        });

        if (typeof window.processAppFlashMessages === 'function') {
          window.processAppFlashMessages();
        }
      });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js" crossorigin="anonymous"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (!window.flatpickr) {
          return;
        }

        flatpickr("input[type='date']:not([data-flatpickr-disabled])", {
          locale: "fr",
          dateFormat: "Y-m-d",
          altInput: true,
          altFormat: "d/m/Y",
          allowInput: true
        });

        flatpickr("input[type='datetime-local']:not([data-flatpickr-disabled])", {
          locale: "fr",
          dateFormat: "Y-m-dTH:i",
          altInput: true,
          altFormat: "d/m/Y à H:i",
          enableTime: true,
          time_24hr: true,
          allowInput: true
        });
      });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
(function () {
  'use strict';
  var toggle  = document.getElementById('sidebarToggleMobile');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebarOverlay');
  if (!toggle || !sidebar || !overlay) return;

  function openSidebar() {
    sidebar.classList.add('sidebar-open');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    toggle.setAttribute('aria-expanded', 'true');
  }

  function closeSidebar() {
    sidebar.classList.remove('sidebar-open');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle.addEventListener('click', openSidebar);
  overlay.addEventListener('click', closeSidebar);

  sidebar.querySelectorAll('a.nav-link').forEach(function (link) {
    link.addEventListener('click', closeSidebar);
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSidebar();
  });
})();
    </script>
</body>
</html>
