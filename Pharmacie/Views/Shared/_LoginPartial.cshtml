@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<ul class="navbar-nav app-nav-user border-top pt-3 pt-xl-0 mt-3 mt-xl-0 align-items-xl-center flex-shrink-0">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link app-nav-link app-nav-user-toggle dropdown-toggle d-flex align-items-center justify-content-center"
           href="#" id="navUserMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true"
           title="Compte (@User.Identity?.Name)">
            <i class="bi bi-person-circle" aria-hidden="true"></i>
            <span class="visually-hidden">Menu compte (@User.Identity?.Name)</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0 app-dropdown-menu app-nav-user-menu py-1" aria-labelledby="navUserMenu">
            <li>
                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <i class="bi bi-gear me-2 text-muted" aria-hidden="true"></i>Mon compte
                </a>
            </li>
            <li><hr class="dropdown-divider my-1" /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="m-0">
                    <button type="submit" class="dropdown-item d-flex align-items-center gap-2">
                        <i class="bi bi-box-arrow-right text-muted" aria-hidden="true"></i>
                        <span>Déconnexion</span>
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item d-xl-flex align-items-xl-center">
        <a class="btn btn-primary btn-sm w-100 w-xl-auto ms-xl-0 mt-2 mt-xl-0" asp-area="Identity" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right me-1" aria-hidden="true"></i>Connexion</a>
    </li>
}
</ul>
