@model IEnumerable<AdminUserRowViewModel>
@using Pharmacie.Authorization
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" crossorigin="anonymous" />
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Gestion des utilisateurs</h1>
            <p class="page-lead mb-0">Comptes utilisateurs et rôles (réservé aux administrateurs).</p>
        </div>
        <a class="btn btn-primary flex-shrink-0" asp-action="Create"><i class="bi bi-person-plus me-1" aria-hidden="true"></i>Créer un utilisateur</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-people" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun utilisateur</p>
        <p class="mb-0 small">Créez un compte pour permettre la connexion au système.</p>
        <a class="btn btn-primary btn-sm mt-3" asp-action="Create"><i class="bi bi-person-plus me-1" aria-hidden="true"></i>Créer un utilisateur</a>
    </div>
}
else
{
    <div class="table-card mb-3">
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle mb-0 js-datatable">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>État</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Email</td>
                            <td>@(string.IsNullOrEmpty(u.RolesDisplay) ? "—" : u.RolesDisplay)</td>
                            <td>
                                @if (u.IsLockedOut)
                                {
                                    <span class="badge bg-danger">Verrouillé</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Actif</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary py-0" asp-action="Edit" asp-route-id="@u.Id">Modifier</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<p class="text-muted small mb-0">
    L'inscription publique est désactivée : seuls les comptes créés ici (ou existants) peuvent se connecter.
</p>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js" crossorigin="anonymous"></script>
    <script>
      $(function () {
        $('.js-datatable').each(function () {
          if ($.fn.DataTable.isDataTable(this)) {
            return;
          }

          $(this).DataTable({
            language: {
              url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json'
            },
            pageLength: 25,
            lengthMenu: [10, 25, 50],
            order: []
          });
        });
      });
    </script>
}
