@model AdminUserCreateViewModel
@{
    ViewData["Title"] = "Créer un utilisateur";
}

<div class="page-header">
    <h1 class="page-title">Créer un utilisateur</h1>
    <nav class="app-breadcrumb mt-2 mb-0 d-inline-block" aria-label="Navigation">
        <a asp-action="Index"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Utilisateurs</a>
    </nav>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-person-plus text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Compte et rôle</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label"></label>
                        <select asp-for="Role" class="form-select" asp-items="ViewBag.Role"></select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2 border-top">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1" aria-hidden="true"></i>Créer</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
