@{
    ViewData["Title"] = "Confidentialité";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <p class="page-lead mb-0">Traitement des données dans l’application.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 p-md-4">
                <p class="mb-3 text-muted">
                    Les données saisies (stocks, ventes, patients) sont stockées dans la base configurée pour votre déploiement.
                    Respectez la réglementation applicable (notamment santé et protection des personnes) et les politiques de votre établissement.
                </p>
                <p class="mb-0 text-muted small">
                    Pour une mise en production : hébergement sécurisé, sauvegardes, droits d’accès et politique de confidentialité adaptés.
                </p>
            </div>
        </div>
    </div>
</div>
