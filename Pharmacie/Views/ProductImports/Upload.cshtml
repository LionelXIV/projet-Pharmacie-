@model ProductImportUploadViewModel
@{
    ViewData["Title"] = "Import produits";
}

<div class="page-header">
    <h1 class="page-title">Import produits</h1>
    <p class="page-lead mb-0">Téléversez un fichier Excel <strong>.xlsx</strong> pour prévisualiser l'import avant confirmation.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-spreadsheet text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Fichier d'import</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <p class="small text-muted mb-3">
                        Colonnes attendues (ordre libre) : <strong>CIP</strong>, <strong>REFHA</strong> (optionnelle),
                        <strong>LIBELLE</strong>, <strong>QTEFACT</strong>, <strong>PX_FAB</strong>, <strong>PPH</strong>.
                    </p>

                    <div class="mb-3">
                        <label asp-for="File" class="form-label"></label>
                        <input asp-for="File" class="form-control" type="file" accept=".xlsx" />
                        <span asp-validation-for="File" class="text-danger"></span>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1" aria-hidden="true"></i>Analyser le fichier
                        </button>
                        <a class="btn btn-outline-secondary" asp-controller="Products" asp-action="Index">Retour au catalogue</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
