@model IReadOnlyList<GoodsReceipt>
@{
    ViewData["Title"] = "Bons de livraison";
    var searchNumber = ViewBag.SearchNumber as string;
    var searchSupplier = ViewBag.SearchSupplier as string;
    var dateFrom = ViewBag.DateFrom as string;
    var dateTo = ViewBag.DateTo as string;
    var hasFilters = !string.IsNullOrEmpty(searchNumber)
        || !string.IsNullOrEmpty(searchSupplier)
        || dateFrom != null
        || dateTo != null;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Bons de livraison</h1>
        <p class="page-lead mb-0">Historique des réceptions enregistrées. Filtrez par numéro, fournisseur ou période.</p>
    </div>
</div>

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="text"
               name="searchNumber"
               value="@ViewBag.SearchNumber"
               class="form-control"
               placeholder="Numéro de BL"
               autocomplete="off">
    </div>
    <div class="col-md-3">
        <input type="text"
               name="searchSupplier"
               value="@ViewBag.SearchSupplier"
               class="form-control"
               placeholder="Fournisseur"
               autocomplete="off">
    </div>
    <div class="col-md-2">
        <input type="date"
               name="dateFrom"
               value="@ViewBag.DateFrom"
               class="form-control"
               data-flatpickr-ignore="true"
               placeholder="Date début"
               title="Date début">
    </div>
    <div class="col-md-2">
        <input type="date"
               name="dateTo"
               value="@ViewBag.DateTo"
               class="form-control"
               data-flatpickr-ignore="true"
               placeholder="Date fin"
               title="Date fin">
    </div>
    <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search" aria-hidden="true"></i> Filtrer
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary" title="Effacer les filtres">
            <i class="bi bi-x-circle" aria-hidden="true"></i>
        </a>
    </div>
</form>

@if (hasFilters)
{
    <div class="alert alert-info py-2 d-flex align-items-center gap-2">
        <i class="bi bi-funnel-fill" aria-hidden="true"></i>
        <span>Filtres actifs — @ViewBag.TotalCount résultat(s)</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-auto">
            Effacer les filtres
        </a>
    </div>
}

<div class="card border-0 shadow-sm table-card mb-3">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-box-seam me-2 text-primary" aria-hidden="true"></i>Réceptions</span>
        @if (Model.Count > 0)
        {
            <span class="badge text-bg-light border">@Model.Count</span>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>N° BL</th>
                    <th>Date</th>
                    <th>Fournisseur</th>
                    <th>Commande</th>
                    <th>Lignes</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge text-bg-light border font-monospace">#@item.Id</span></td>
                        <td class="text-nowrap">@item.ReceivedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-medium">@(item.PurchaseOrder?.Supplier?.Name ?? "—")</td>
                        <td><span class="font-monospace">#@item.PurchaseOrderId</span></td>
                        <td>@item.Lines.Count</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-controller="PurchaseOrders"
                               asp-action="Details"
                               asp-route-id="@item.PurchaseOrderId"
                               title="Voir la commande">
                                <i class="bi bi-eye" aria-hidden="true"></i><span class="d-none d-md-inline ms-1">Commande</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <small class="text-muted px-3 pb-2 d-block">
        @ViewBag.TotalCount réception(s) au total
    </small>
    <div class="px-3 pb-3">
        <partial name="_Pagination" />
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-box-seam" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucune réception</p>
        <p class="mb-0 small">Aucun résultat pour ces critères.</p>
    </div>
}
