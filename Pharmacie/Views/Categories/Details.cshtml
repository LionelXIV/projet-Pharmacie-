@model Category
@{
    ViewData["Title"] = "Détails catégorie";
}

<div class="page-header">
    <h1 class="page-title">@Model.Name</h1>
    <nav class="app-breadcrumb mt-2 mb-0 d-inline-block" aria-label="Navigation">
        <a asp-action="Index">Catégories</a>
    </nav>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3 p-md-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Name)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>
                </dl>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil me-1" aria-hidden="true"></i>Modifier</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Retour à la liste</a>
        </div>
    </div>
</div>
