@model Patient
@{
    ViewData["Title"] = "Nouveau patient";
}

<div class="page-header">
    <h1 class="page-title">Nouveau patient</h1>
    <p class="page-lead mb-0">Coordonnées et informations de santé.</p>
</div>

<form asp-action="Create" method="post" class="card border-0 shadow-sm">
    <div class="card-body p-3 p-md-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <partial name="_PatientFormFields" model="Model" />
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
