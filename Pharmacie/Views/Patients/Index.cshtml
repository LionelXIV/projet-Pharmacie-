@model IReadOnlyList<Patient>
@{
    ViewData["Title"] = "Patients";
    var canManage = ViewBag.CanManage as bool? == true;
    var activeRx = ViewBag.ActivePrescriptions as HashSet<int> ?? new HashSet<int>();
    var pendingRx = ViewBag.PendingReminders as Dictionary<int, int> ?? new Dictionary<int, int>();

    string GetInitials(string fullName)
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1)
            return parts[0].Length >= 2 ? parts[0][..2].ToUpperInvariant() : parts[0].ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Portefeuille patients</h1>
            <p class="page-lead mb-0">Coordonnées, informations de santé, ordonnances et rappels.</p>
        </div>
        @if (canManage)
        {
            <a class="btn btn-primary flex-shrink-0" asp-action="Create"><i class="bi bi-person-plus me-1" aria-hidden="true"></i>Nouveau patient</a>
        }
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtres</h2>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small mb-0" for="q">Recherche (nom, téléphone, courriel)</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                    <input type="search" name="q" id="q" value="@ViewBag.Query" class="form-control" placeholder="Rechercher…" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-0" for="active">État</label>
                @{
                    var act = ViewBag.Active as string;
                }
                <select name="active" id="active" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(act))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (act == "1")
                    {
                        <option value="1" selected>Actifs</option>
                    }
                    else
                    {
                        <option value="1">Actifs</option>
                    }
                    @if (act == "0")
                    {
                        <option value="0" selected>Inactifs</option>
                    }
                    else
                    {
                        <option value="0">Inactifs</option>
                    }
                </select>
            </div>
            <div class="col-auto d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
                <a class="btn btn-outline-primary btn-sm" asp-action="IndexCsv" asp-route-q="@ViewBag.Query" asp-route-active="@ViewBag.Active" title="Mêmes filtres que ci-dessus">
                    <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
                </a>
            </div>
        </form>
        <p class="small text-muted mb-0 mt-2">
            Exports globaux (tous les patients) :
            <a asp-action="PrescriptionsCsv">ordonnances</a>,
            <a asp-action="RemindersCsv">rappels</a>.
        </p>
    </div>
</div>

<div class="card border-0 shadow-sm table-card mb-3">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-people me-2 text-primary" aria-hidden="true"></i>Patients</span>
        @if (Model.Count > 0)
        {
            <span class="badge text-bg-light border">@Model.Count</span>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Patient</th>
                    <th>Coordonnées</th>
                    <th>État</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <span class="rounded-circle bg-primary-subtle text-primary-emphasis d-inline-flex align-items-center justify-content-center flex-shrink-0 fw-semibold"
                                      style="width: 2.5rem; height: 2.5rem; font-size: 0.85rem;"
                                      aria-hidden="true">@GetInitials(p.FullName)</span>
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">
                                        @p.FullName
                                        @if (activeRx.Contains(p.Id))
                                        {
                                            <span class="badge bg-success-subtle text-success ms-1"
                                                  title="Ordonnance active">
                                                <i class="bi bi-file-medical" aria-hidden="true"></i> Ord. active
                                            </span>
                                        }
                                        @{
                                            var pending = pendingRx.GetValueOrDefault(p.Id, 0);
                                        }
                                        @if (pending > 0)
                                        {
                                            <span class="badge bg-warning-subtle text-warning ms-1"
                                                  title="@pending rappel(s) en attente">
                                                <i class="bi bi-bell-fill" aria-hidden="true"></i> @pending rappel@(pending > 1 ? "s" : "")
                                            </span>
                                        }
                                    </div>
                                    <div class="small text-muted">Fiche n° @p.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1 small">
                                @if (!string.IsNullOrWhiteSpace(p.Phone))
                                {
                                    <span class="text-nowrap"><i class="bi bi-telephone me-1 text-muted" aria-hidden="true"></i>@p.Phone</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.Email))
                                {
                                    <span class="text-truncate"><i class="bi bi-envelope me-1 text-muted" aria-hidden="true"></i>@p.Email</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-envelope me-1" aria-hidden="true"></i>—</span>
                                }
                            </div>
                        </td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge text-bg-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Inactif</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@p.Id" title="Voir la fiche" data-bs-toggle="tooltip">
                                <i class="bi bi-person-lines-fill" aria-hidden="true"></i><span class="d-none d-lg-inline ms-1">Fiche</span>
                            </a>
                            @if (canManage)
                            {
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id" title="Modifier" data-bs-toggle="tooltip">
                                    <i class="bi bi-pencil" aria-hidden="true"></i><span class="d-none d-lg-inline ms-1">Modifier</span>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="table-card-caption">@Model.Count patient(s).</div>
    }
</div>
@if (Model.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-person-x" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun patient</p>
        <p class="mb-0 small">Ajustez les filtres ou créez une fiche.</p>
    </div>
}

@section Scripts {
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
          new bootstrap.Tooltip(el);
        });
      });
    </script>
}
