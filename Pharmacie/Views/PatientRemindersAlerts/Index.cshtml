@model IReadOnlyList<PatientTreatmentReminder>
@{
    ViewData["Title"] = "Rappels patients à traiter";
    var canManage = ViewBag.CanManage as bool? == true;
    var today = (DateTime)ViewBag.Today!;
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Rappels à traiter</h1>
            <p class="page-lead mb-0">Rappels <strong>non marqués « fait »</strong> dont la date est le <strong>@today.ToString("yyyy-MM-dd")</strong> ou antérieure. Aucun envoi SMS ou WhatsApp (fonctionnalité interne uniquement).</p>
        </div>
        <a class="btn btn-outline-secondary btn-sm flex-shrink-0" asp-controller="Patients" asp-action="Index">Portefeuille</a>
    </div>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Patient</th>
                    <th>Type</th>
                    <th>Message</th>
                    @if (canManage)
                    {
                        <th class="text-end">Action</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr class="@(r.ReminderDate < today ? "table-danger" : "table-warning")">
                        <td class="text-nowrap">@r.ReminderDate.ToString("yyyy-MM-dd")</td>
                        <td><a asp-controller="Patients" asp-action="Details" asp-route-id="@r.PatientId">@(r.Patient?.FullName ?? $"#{r.PatientId}")</a></td>
                        <td>@PatientUiLabels.ReminderType(r.ReminderType)</td>
                        <td class="small">@r.Message</td>
                        @if (canManage)
                        {
                            <td class="text-end">
                                <form asp-controller="PatientReminders" asp-action="MarkDone" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-success py-0">Marquer fait</button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count == 0)
    {
        <div class="table-card-caption">Aucun rappel en attente pour cette période.</div>
    }
</div>
