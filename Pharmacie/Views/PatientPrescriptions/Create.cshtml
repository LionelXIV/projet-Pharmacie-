@model PatientPrescription
@{
    ViewData["Title"] = "Nouvelle ordonnance";
}

<div class="page-header">
    <h1 class="page-title">Nouvelle ordonnance</h1>
    <p class="page-lead mb-0">Patient : <strong>@ViewBag.PatientName</strong></p>
</div>

<form asp-action="Create" method="post" class="card border-0 shadow-sm">
    <input type="hidden" asp-for="PatientId" />
    <div class="card-body p-3 p-md-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="PrescribedAt" class="form-label"></label>
                <input asp-for="PrescribedAt" class="form-control" type="date" />
                <span asp-validation-for="PrescribedAt" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DoctorName" class="form-label"></label>
                <input asp-for="DoctorName" class="form-control" />
                <span asp-validation-for="DoctorName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="RenewalDate" class="form-label"></label>
                <input asp-for="RenewalDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<PrescriptionStatus>()"></select>
            </div>
            <div class="col-12">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a class="btn btn-outline-secondary" asp-controller="Patients" asp-action="Details" asp-route-id="@Model.PatientId">Annuler</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
