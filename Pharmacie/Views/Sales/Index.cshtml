@model SaleIndexPageViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Pharmacie.Services
@{
    ViewData["Title"] = "Ventes";
    var userLabels = ViewBag.UserLabels as Dictionary<string, string> ?? new Dictionary<string, string>();
    var filterUserList = ViewData["FilterUserId"] as IEnumerable<SelectListItem>;
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Ventes</h1>
            <p class="page-lead mb-0">Historique des ventes. <strong>Enregistré par</strong> : utilisateur connecté lors de la validation.</p>
        </div>
        <div class="flex-shrink-0">
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-cash-register me-1" aria-hidden="true"></i>Nouvelle vente</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtres</h2>
        <p class="small text-muted mb-3">
            <strong>Du / Au</strong> : plage sur la <em>date-heure de vente</em> (inclusif sur les jours calendaires choisis).
            <strong>Utilisateur</strong> : restreint aux ventes enregistrées par ce compte (liste dérivée des ventes existantes).
        </p>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="From">Du</label>
                <input type="date" name="From" id="From" value="@(Model.Filter.From?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="To">Au</label>
                <input type="date" name="To" id="To" value="@(Model.Filter.To?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4 col-lg-4">
                <label class="form-label small mb-0" for="UserId">Utilisateur</label>
                <select name="UserId" id="UserId" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.UserId))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (filterUserList != null)
                    {
                        @foreach (var opt in filterUserList)
                        {
                            if (Model.Filter.UserId == opt.Value)
                            {
                                <option value="@opt.Value" selected>@opt.Text</option>
                            }
                            else
                            {
                                <option value="@opt.Value">@opt.Text</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 pt-1 pt-lg-0">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm table-card mb-3">
    <div class="card-header bg-white border-bottom py-3">
        <span class="fw-semibold"><i class="bi bi-receipt me-2 text-primary" aria-hidden="true"></i>Historique des ventes</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th><i class="bi bi-hash text-muted me-1" aria-hidden="true"></i>N°</th>
                    <th><i class="bi bi-calendar3 text-muted me-1" aria-hidden="true"></i>Date</th>
                    <th class="text-end"><i class="bi bi-list-ul text-muted me-1" aria-hidden="true"></i>Lignes</th>
                    <th class="text-end"><i class="bi bi-currency-euro text-muted me-1" aria-hidden="true"></i>Total</th>
                    <th><i class="bi bi-person text-muted me-1" aria-hidden="true"></i>Enregistré par</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Sales)
                {
                    var lineCount = s.Lines?.Count ?? 0;
                    var total = s.Lines?.Sum(l => l.Quantity * l.UnitPrice) ?? 0m;
                    <tr>
                        <td><span class="badge text-bg-light border font-monospace">#@s.Id</span></td>
                        <td class="text-nowrap small">@s.SoldAt.ToString("g")</td>
                        <td class="text-end">
                            <span class="badge text-bg-secondary-subtle text-secondary-emphasis border">@lineCount</span>
                        </td>
                        <td class="text-end">
                            <span class="fw-bold text-success-emphasis fs-6">@total.ToString("0.00") €</span>
                        </td>
                        <td class="small">
                            <i class="bi bi-person-circle me-1 text-muted" aria-hidden="true"></i>@UserDisplayResolver.Resolve(userLabels, s.UserId)
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@s.Id" title="Voir le détail" data-bs-toggle="tooltip">
                                <i class="bi bi-eye" aria-hidden="true"></i><span class="d-none d-md-inline ms-1">Détail</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Sales.Count > 0)
    {
        <div class="table-card-caption d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 px-3 py-2">
            <span>@Model.Sales.Count vente(s) sur @(ViewBag.TotalCount ?? 0) · page @(ViewBag.CurrentPage ?? 1)/@(ViewBag.TotalPages ?? 1)</span>
            @{
                var paginationRoutes = new Dictionary<string, string>();
                if (Model.Filter.From.HasValue)
                    paginationRoutes["From"] = Model.Filter.From.Value.ToString("yyyy-MM-dd");
                if (Model.Filter.To.HasValue)
                    paginationRoutes["To"] = Model.Filter.To.Value.ToString("yyyy-MM-dd");
                if (!string.IsNullOrEmpty(Model.Filter.UserId))
                    paginationRoutes["UserId"] = Model.Filter.UserId;
                ViewBag.PaginationRoutes = paginationRoutes;
            }
            <partial name="_Pagination" />
        </div>
    }
</div>
@if (Model.Sales.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-cart-x" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucune vente</p>
        <p class="mb-0 small">Aucun résultat pour ces critères.</p>
        <a class="btn btn-primary btn-sm mt-3" asp-action="Create"><i class="bi bi-cash-register me-1" aria-hidden="true"></i>Nouvelle vente</a>
    </div>
}

@section Scripts {
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
          new bootstrap.Tooltip(el);
        });
      });
    </script>
}
