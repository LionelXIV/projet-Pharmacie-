@model Sale
@{
    ViewData["Title"] = "Détail de la vente";
    var total = Model.Lines.Sum(l => l.Quantity * l.UnitPrice);
}

<div class="page-header">
    <h1 class="page-title">Vente #@Model.Id</h1>
    <p class="page-lead mb-0">@Model.SoldAt.ToString("g")</p>
    <p class="small text-muted mb-0 mt-2">Enregistré par : <strong>@(ViewBag.RecordedBy ?? "—")</strong></p>
</div>

<div class="row">
    <div class="col-lg-9">
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <p class="mb-0"><strong>Notes :</strong> @Model.Notes</p>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-receipt text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Lignes</span>
            </div>
            <div class="card-body p-0">
                <p class="app-scroll-hint d-md-none mb-0 rounded-0" role="note">Faites défiler horizontalement si besoin.</p>
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th class="text-end">Prix unit.</th>
                                <th class="text-end">Qté</th>
                                <th class="text-end">Sous-total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines.OrderBy(l => l.Id))
                            {
                                var sub = line.Quantity * line.UnitPrice;
                                <tr>
                                    <td>@line.Product?.CommercialName</td>
                                    <td class="text-end">@line.UnitPrice.ToString("0.00") €</td>
                                    <td class="text-end">@line.Quantity</td>
                                    <td class="text-end">@sub.ToString("0.00") €</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Total</th>
                                <th class="text-end">@total.ToString("0.00") €</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <p class="small text-muted">Détail des sorties par lot : <a asp-controller="StockMovements" asp-action="Index">Mouvements de stock</a>.</p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Retour à la liste</a>
            <a class="btn btn-outline-primary" asp-action="DetailsCsv" asp-route-id="@Model.Id"><i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV (lignes)</a>
        </div>
    </div>
</div>
