@model AlertsIndexViewModel
@{
    ViewData["Title"] = "Alertes";
    var today = Model.Today;
}

<div class="page-header">
    <h1 class="page-title">Alertes</h1>
    <p class="page-lead mb-0">Produits sous le seuil d'alerte et lots proches ou après la date de péremption (fenêtre <strong>@ViewBag.HorizonDays</strong> jours).</p>
</div>

<form method="get" asp-action="Index"
      class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <label class="text-muted small fw-semibold mb-0" for="horizonDays">
        <i class="bi bi-calendar-event" aria-hidden="true"></i>
        Alertes péremption dans moins de
    </label>
    <input type="number" name="horizonDays" id="horizonDays"
           value="@ViewBag.HorizonDays"
           min="7" max="365"
           class="form-control form-control-sm"
           style="width: 80px"
           title="Nombre de jours">
    <span class="text-muted small">jours</span>
    <button type="submit" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-funnel" aria-hidden="true"></i> Appliquer
    </button>
    @if ((int)ViewBag.HorizonDays != (int)ViewBag.DefaultHorizonDays)
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x-circle" aria-hidden="true"></i> Réinitialiser
        </a>
    }
</form>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span class="fw-semibold d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle text-warning fs-5" aria-hidden="true"></i>
                    Stock bas
                </span>
                @if (Model.LowStockProducts.Count > 0)
                {
                    <span class="badge text-bg-warning">@Model.LowStockProducts.Count</span>
                }
            </div>
            @if (Model.LowStockProducts.Count == 0)
            {
                <div class="card-body">
                    <div class="app-empty-state app-empty-state--compact border-0 mb-0" role="status">
                        <i class="bi bi-check-circle text-success" aria-hidden="true"></i>
                        <p class="app-empty-state-title mb-1">Stock bas — rien à signaler</p>
                        <p class="mb-0 small">Aucun produit actif sous son seuil d'alerte.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Urgence</th>
                                <th>Produit</th>
                                <th class="text-end">Stock</th>
                                <th class="text-end">Seuil</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.LowStockProducts)
                            {
                                var isOut = p.StockQuantity == 0;
                                <tr>
                                    <td>
                                        @if (isOut)
                                        {
                                            <span class="badge text-bg-danger"><i class="bi bi-x-octagon me-1" aria-hidden="true"></i>Rupture</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-warning"><i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>Faible</span>
                                        }
                                    </td>
                                    <td class="fw-medium">@p.CommercialName</td>
                                    <td class="text-end">
                                        <span class="badge @(isOut ? "text-bg-danger" : "text-bg-warning")">@p.StockQuantity</span>
                                    </td>
                                    <td class="text-end text-muted">@p.AlertThreshold</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" title="Ouvrir la fiche produit" data-bs-toggle="tooltip">
                                            <i class="bi bi-capsule" aria-hidden="true"></i><span class="d-none d-md-inline ms-1">Fiche</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white border-top small text-muted">@Model.LowStockProducts.Count produit(s) concerné(s).</div>
                {
                    ViewBag.CurrentPage = ViewBag.StockCurrentPage;
                    ViewBag.TotalPages = ViewBag.StockTotalPages;
                    ViewBag.PaginationRoutes = ViewBag.PaginationRoutesStock;
                }
                <partial name="_Pagination" />
            }
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span class="fw-semibold d-flex align-items-center gap-2">
                    <i class="bi bi-hourglass-split text-danger fs-5" aria-hidden="true"></i>
                    Péremption des lots
                </span>
                @if (Model.BatchesNearingExpiration.Count > 0)
                {
                    <span class="badge text-bg-danger">@Model.BatchesNearingExpiration.Count</span>
                }
            </div>
            @if (Model.BatchesNearingExpiration.Count == 0)
            {
                <div class="card-body">
                    <div class="app-empty-state app-empty-state--compact border-0 mb-0" role="status">
                        <i class="bi bi-calendar-check text-success" aria-hidden="true"></i>
                        <p class="app-empty-state-title mb-1">Péremption — RAS</p>
                        <p class="mb-0 small">Aucun lot avec stock dans la fenêtre de péremption.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Statut</th>
                                <th>Produit</th>
                                <th>Lot</th>
                                <th>Expiration</th>
                                <th class="text-end">Qté</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.BatchesNearingExpiration)
                            {
                                var exp = b.ExpirationDate.Date;
                                var days = (exp - today).Days;
                                string badgeClass;
                                string label;
                                string rowClass = "";
                                if (days < 0)
                                {
                                    badgeClass = "text-bg-danger";
                                    label = $"Expiré ({-days} j.)";
                                    rowClass = "table-danger-subtle";
                                }
                                else if (days <= 30)
                                {
                                    badgeClass = "text-bg-warning";
                                    label = days == 0 ? "Expire aujourd'hui" : $"≤ 30 j. ({days} j.)";
                                    rowClass = "table-warning-subtle";
                                }
                                else
                                {
                                    badgeClass = "text-bg-info";
                                    label = $"{days} j.";
                                }
                                <tr class="@rowClass">
                                    <td><span class="badge @badgeClass">@label</span></td>
                                    <td class="fw-medium">@b.Product?.CommercialName</td>
                                    <td><span class="font-monospace small">@b.LotNumber</span></td>
                                    <td class="text-nowrap">@exp.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end"><span class="badge text-bg-light border">@b.Quantity</span></td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Batches" asp-action="Details" asp-route-id="@b.Id" title="Voir le lot" data-bs-toggle="tooltip">
                                            <i class="bi bi-layers" aria-hidden="true"></i><span class="d-none d-md-inline ms-1">Lot</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white border-top small text-muted">@Model.BatchesNearingExpiration.Count lot(s) dans la fenêtre.</div>
                {
                    ViewBag.CurrentPage = ViewBag.ExpirationCurrentPage;
                    ViewBag.TotalPages = ViewBag.ExpirationTotalPages;
                    ViewBag.PaginationRoutes = ViewBag.PaginationRoutesExpiration;
                }
                <partial name="_Pagination" />
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
          new bootstrap.Tooltip(el);
        });
      });
    </script>
}
