@model IEnumerable<Supplier>
@{
    ViewData["Title"] = "Fournisseurs";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" crossorigin="anonymous" />
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Fournisseurs</h1>
            <p class="page-lead mb-0">Référentiel des distributeurs et laboratoires.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <a class="btn btn-outline-primary" asp-action="IndexCsv"><i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV</a>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau fournisseur</a>
        </div>
    </div>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
        <table class="table table-striped table-sm mb-0 js-datatable">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                    <th>@Html.DisplayNameFor(m => m.Contact)</th>
                    <th>@Html.DisplayNameFor(m => m.Phone)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(m => item.Name)</td>
                        <td>@Html.DisplayFor(m => item.Contact)</td>
                        <td>@Html.DisplayFor(m => item.Phone)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary py-0" asp-action="Details" asp-route-id="@item.Id">Détails</a>
                            <a class="btn btn-sm btn-outline-primary py-0" asp-action="Edit" asp-route-id="@item.Id">Modifier</a>
                            <a class="btn btn-sm btn-outline-danger py-0" asp-action="Delete" asp-route-id="@item.Id">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js" crossorigin="anonymous"></script>
    <script>
      $(function () {
        $('.js-datatable').each(function () {
          if ($.fn.DataTable.isDataTable(this)) {
            return;
          }

          $(this).DataTable({
            language: {
              url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json'
            },
            pageLength: 25,
            lengthMenu: [10, 25, 50],
            order: []
          });
        });
      });
    </script>
}
