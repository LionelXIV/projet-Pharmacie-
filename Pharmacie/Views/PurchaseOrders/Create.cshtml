@model PurchaseOrderCreateViewModel
@{
    ViewData["Title"] = "Nouvelle commande";
}

<div class="page-header">
    <h1 class="page-title">Nouvelle commande</h1>
    <p class="page-lead mb-0">Renseignez une ou plusieurs lignes (produit + quantité). Les lignes vides sont ignorées.</p>
</div>

<div class="row">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-bag-check text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Commande fournisseur</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Create" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <p class="form-section-title">En-tête</p>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="SupplierId" class="form-label"></label>
                            <select asp-for="SupplierId" class="form-select" asp-items="@((SelectList)ViewData["SupplierId"]!)">
                                <option value="0">— Fournisseur —</option>
                            </select>
                            <span asp-validation-for="SupplierId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrderDate" class="form-label"></label>
                            <input asp-for="OrderDate" class="form-control" type="date" />
                            <span asp-validation-for="OrderDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <input asp-for="Notes" class="form-control" />
                    </div>

                    <p class="form-section-title">Lignes</p>
                    <p class="app-scroll-hint d-md-none mb-2" role="note">Sur petit écran, faites défiler horizontalement le tableau.</p>
                    <div class="table-card mb-3">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Produit</th>
                                        <th style="width:8rem">Quantité</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Lines.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-1">
                                                    <select asp-for="Lines[i].ProductId"
                                                            class="form-select form-select-sm tomselect-product flex-grow-1"
                                                            data-tomselect-product
                                                            data-val="false"
                                                            data-url="@Url.Action("Search", "Products")">
                                                        <option value="0"></option>
                                                    </select>
                                                    <button type="button"
                                                            class="btn btn-outline-success btn-sm flex-shrink-0"
                                                            title="Créer un nouveau produit"
                                                            onclick="openQuickProductModal(this)">
                                                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                                    </button>
                                                </div>
                                            </td>
                                            <td>
                                                <input asp-for="Lines[i].QuantityOrdered" class="form-control form-control-sm" type="number" min="0" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2 border-top">
                        <button type="submit" name="submitAction" value="draft" class="btn btn-outline-secondary">
                            <i class="bi bi-file-earmark me-1" aria-hidden="true"></i>Enregistrer en brouillon
                        </button>
                        <button type="submit" name="submitAction" value="send" class="btn btn-primary">
                            <i class="bi bi-send me-1" aria-hidden="true"></i>Créer et envoyer
                        </button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <partial name="_QuickProductModal" />
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (!window.TomSelect) return;

        document.querySelectorAll('[data-tomselect-product]').forEach(function (el) {
          if (el.tomselect) return;

          new TomSelect(el, {
            valueField: 'value',
            labelField: 'text',
            searchField: ['text'],
            placeholder: 'Tapez au moins 2 caractères...',
            maxOptions: 25,
            preload: false,
            create: false,
            loadThrottle: 300,
            load: function (query, callback) {
              if (!query || query.length < 2) {
                callback();
                return;
              }

              const url = (el.dataset.url || '/Products/Search') + '?term=' + encodeURIComponent(query);

              fetch(url)
                .then(function (response) { return response.json(); })
                .then(function (data) { callback(data); })
                .catch(function () { callback(); });
            },
            onChange: function (value) {
              if (!value) return;

              const option = this.options[value];
              if (!option) return;

              const selectName = el.getAttribute('name');
              if (!selectName) return;

              const priceName = selectName.replace('ProductId', 'UnitPrice');
              const priceInput = document.querySelector('[name="' + priceName + '"]');

              if (priceInput && option.purchasePrice !== undefined && option.purchasePrice !== null) {
                priceInput.value = option.purchasePrice;
              }
            },
            render: {
              option: function (data, escape) {
                return '<div>' + escape(data.text) + '</div>';
              },
              item: function (data, escape) {
                return '<div>' + escape(data.text) + '</div>';
              },
              no_results: function (data, escape) {
                return '<div class="no-results">Aucun produit trouvé pour "' + escape(data.input) + '"</div>';
              },
              loading: function () {
                return '<div class="loading">Recherche en cours...</div>';
              }
            }
          });
        });
      });
    </script>
}
