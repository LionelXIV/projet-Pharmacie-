@model PurchaseOrderCreateViewModel
@{
    ViewData["Title"] = "Nouvelle commande";
    var productList = ViewData["ProductOptions"] as SelectList;
}

<div class="page-header">
    <h1 class="page-title">Nouvelle commande</h1>
    <p class="page-lead mb-0">Renseignez une ou plusieurs lignes (produit + quantité). Les lignes vides sont ignorées.</p>
</div>

<div class="row">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-bag-check text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Commande fournisseur</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <p class="form-section-title">En-tête</p>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="SupplierId" class="form-label"></label>
                            <select asp-for="SupplierId" class="form-select" asp-items="@((SelectList)ViewData["SupplierId"]!)">
                                <option value="0">— Fournisseur —</option>
                            </select>
                            <span asp-validation-for="SupplierId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrderDate" class="form-label"></label>
                            <input asp-for="OrderDate" class="form-control" type="date" />
                            <span asp-validation-for="OrderDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <input asp-for="Notes" class="form-control" />
                    </div>

                    <p class="form-section-title">Lignes</p>
                    <p class="app-scroll-hint d-md-none mb-2" role="note">Sur petit écran, faites défiler horizontalement le tableau.</p>
                    <div class="table-card mb-3">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Produit</th>
                                        <th style="width:8rem">Quantité</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Lines.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <select asp-for="Lines[i].ProductId" class="form-select form-select-sm" asp-items="productList">
                                                    <option value="0">—</option>
                                                </select>
                                            </td>
                                            <td>
                                                <input asp-for="Lines[i].QuantityOrdered" class="form-control form-control-sm" type="number" min="0" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2 border-top">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1" aria-hidden="true"></i>Enregistrer la commande</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
