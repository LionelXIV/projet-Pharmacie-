@model PurchaseOrder
@{
    ViewData["Title"] = $"Commande #{Model.Id}";
    string StatusLabel(PurchaseOrderStatus s) => s switch
    {
        PurchaseOrderStatus.Brouillon => "Brouillon",
        PurchaseOrderStatus.Envoyee => "Envoyée",
        PurchaseOrderStatus.PartiellementRecue => "Partiellement reçue",
        PurchaseOrderStatus.Recue => "Reçue",
        PurchaseOrderStatus.Annulee => "Annulée",
        _ => s.ToString()
    };
    var canReceive = Model.Status != PurchaseOrderStatus.Annulee
        && Model.Status != PurchaseOrderStatus.Recue
        && Model.Lines.Any(l => l.QuantityOrdered > l.QuantityReceived);
    var canCancel = Model.Status != PurchaseOrderStatus.Annulee
        && Model.Status != PurchaseOrderStatus.Recue
        && Model.Lines.All(l => l.QuantityReceived == 0);
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Commande #@Model.Id</h1>
            <nav class="app-breadcrumb mt-2 mb-0 d-inline-block" aria-label="Navigation">
                <a asp-action="Index">Liste des commandes</a>
            </nav>
        </div>
        @if (canReceive)
        {
            <a class="btn btn-primary flex-shrink-0" asp-controller="GoodsReceipts" asp-action="Create" asp-route-purchaseOrderId="@Model.Id"><i class="bi bi-box-arrow-in-down me-1" aria-hidden="true"></i>Réception</a>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-info-circle text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Résumé</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Fournisseur</dt>
                    <dd class="col-sm-9">@Model.Supplier?.Name</dd>
                    <dt class="col-sm-3">Date</dt>
                    <dd class="col-sm-9">@Model.OrderDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3">Statut</dt>
                    <dd class="col-sm-9">@StatusLabel(Model.Status)</dd>
                    <dt class="col-sm-3">Notes</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</dd>
                </dl>
            </div>
        </div>

        <h2 class="h5 mb-3">Lignes</h2>
        <div class="table-card mb-4">
            <p class="app-scroll-hint d-md-none mb-0 rounded-0 rounded-top" role="note">Défilement horizontal possible.</p>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th>Commandée</th>
                            <th>Reçue</th>
                            <th>Reste</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.Lines.OrderBy(l => l.Id))
                        {
                            var reste = line.QuantityOrdered - line.QuantityReceived;
                            <tr>
                                <td>@line.Product?.CommercialName</td>
                                <td>@line.QuantityOrdered</td>
                                <td>@line.QuantityReceived</td>
                                <td>@reste</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Receipts.Any())
        {
            <h2 class="h5 mb-3">Réceptions</h2>
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3 p-md-4">
                    <ul class="list-unstyled mb-0">
                        @foreach (var r in Model.Receipts.OrderByDescending(r => r.ReceivedAt))
                        {
                            <li class="mb-3 pb-3 border-bottom border-light">
                                <strong>@r.ReceivedAt.ToString("g")</strong>
                                @if (!string.IsNullOrEmpty(r.Notes))
                                {
                                    <span class="text-muted"> — @r.Notes</span>
                                }
                                <ul class="mt-2 mb-0">
                                    @foreach (var rl in r.Lines)
                                    {
                                        <li>Qté @rl.QuantityReceived, lot @rl.LotNumber, exp. @rl.ExpirationDate.ToString("yyyy-MM-dd")</li>
                                    }
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }

        @if (Model.Status == PurchaseOrderStatus.Brouillon)
        {
            <form asp-action="Send" asp-route-id="@Model.Id" method="post" class="mt-2 mb-3">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary" data-confirm="Confirmer l'envoi de cette commande ?">
                    <i class="bi bi-send me-1" aria-hidden="true"></i>Envoyer
                </button>
            </form>
        }

        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="mt-2 mb-3">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger" data-confirm="Annuler cette commande fournisseur ? Cette action est irréversible.">Annuler la commande</button>
            </form>
        }
    </div>
</div>
