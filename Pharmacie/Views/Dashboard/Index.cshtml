@model DashboardViewModel
@using Pharmacie.Models
@{
    ViewData["Title"] = "Tableau de bord";
    string MovementLabel(StockMovementType t) => t switch
    {
        StockMovementType.Entree => "Entrée",
        StockMovementType.Sortie => "Sortie",
        StockMovementType.Ajustement => "Ajustement",
        _ => t.ToString()
    };
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Tableau de bord</h1>
            <p class="page-lead mb-0">
                <strong>@Model.Today.ToString("dddd d MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</strong>
                · Péremption des lots sur <strong>@Model.ExpirationHorizonDays</strong> jours (même fenêtre que les alertes).
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-cta btn-sm" asp-controller="Reports" asp-action="Index"><i class="bi bi-clipboard2-data me-1" aria-hidden="true"></i>Rapports</a>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Alerts" asp-action="Index"><i class="bi bi-bell me-1" aria-hidden="true"></i>Alertes</a>
        </div>
    </div>
</div>

<h2 class="app-dash-section-title">Indicateurs clés</h2>
<div class="row row-cols-2 row-cols-md-3 row-cols-xl-6 g-3 mb-4">
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Produits</span>
                    <i class="bi bi-capsule app-kpi-icon fs-5 text-primary" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold text-body lh-1 mb-1">@Model.TotalProducts</div>
                <span class="small text-muted">Catalogue total</span>
                <a class="small d-block mt-2 stretched-link text-decoration-none" asp-controller="Products" asp-action="Index">Voir le catalogue</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card app-kpi-card--accent-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Stock faible</span>
                    <i class="bi bi-exclamation-triangle app-kpi-icon fs-5 text-warning" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold text-warning-emphasis lh-1 mb-1">@Model.LowStockProductsCount</div>
                <span class="small text-muted">Sous le seuil</span>
                <a class="small d-block mt-2" asp-controller="Alerts" asp-action="Index">Voir alertes</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card app-kpi-card--accent-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Rupture</span>
                    <i class="bi bi-x-octagon app-kpi-icon fs-5 text-danger" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold text-danger lh-1 mb-1">@Model.OutOfStockProductsCount</div>
                <span class="small text-muted">Stock nul</span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card app-kpi-card--accent-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Péremption proche</span>
                    <i class="bi bi-hourglass-split app-kpi-icon fs-5 text-info" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold text-info-emphasis lh-1 mb-1">@Model.NearExpiryLotsCount</div>
                <span class="small text-muted">Lots non expirés</span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card app-kpi-card--accent-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Lots expirés</span>
                    <i class="bi bi-calendar-x app-kpi-icon fs-5 text-danger" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold text-danger lh-1 mb-1">@Model.ExpiredLotsCount</div>
                <span class="small text-muted">Encore en stock</span>
                <a class="small d-block mt-2" asp-controller="Batches" asp-action="Index">Voir les lots</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Commandes</span>
                    <i class="bi bi-truck app-kpi-icon fs-5 text-secondary" aria-hidden="true"></i>
                </div>
                <div class="display-6 fw-bold lh-1 mb-1">@Model.PendingPurchaseOrdersCount</div>
                <span class="small text-muted">En cours</span>
                <a class="small d-block mt-2" asp-controller="PurchaseOrders" asp-action="Index">Commandes</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100 app-kpi-card app-kpi-card--accent-sales">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <span class="text-muted small text-uppercase fw-semibold">Ventes du jour</span>
                    <i class="bi bi-cart-check app-kpi-icon fs-5 text-success" aria-hidden="true"></i>
                </div>
                <div class="fs-3 fw-bold lh-1 mb-1">@Model.SalesTodayCount</div>
                <span class="small text-muted d-block">@Model.SalesTodayTotal.ToString("0.00") € de CA</span>
                <a class="small d-block mt-2" asp-controller="Sales" asp-action="Index">Historique</a>
            </div>
        </div>
    </div>
    @if (Model.ShowPatientDashboardWidget)
    {
        <div class="col">
            <div class="card border-0 shadow-sm h-100 app-kpi-card border-primary-subtle">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <span class="text-muted small text-uppercase fw-semibold">Rappels patients</span>
                        <i class="bi bi-alarm app-kpi-icon fs-5 text-primary" aria-hidden="true"></i>
                    </div>
                    <div class="display-6 fw-bold text-primary-emphasis lh-1 mb-1">@Model.PatientRemindersDueCount</div>
                    <span class="small text-muted">À traiter aujourd'hui</span>
                    <a class="small d-block mt-2" asp-controller="PatientRemindersAlerts" asp-action="Index">Voir la liste</a>
                </div>
            </div>
        </div>
    }
</div>

<h2 class="app-dash-section-title">Graphiques</h2>
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <span class="fw-semibold"><i class="bi bi-graph-up me-2 text-primary" aria-hidden="true"></i>Ventes des 30 derniers jours</span>
            </div>
            <div class="card-body">
                <div class="ph-chart-container" style="height: 280px;">
                    <canvas id="salesChart" aria-label="Graphique des ventes sur 30 jours" role="img"></canvas>
                </div>
                <p class="small text-muted mb-0 mt-2">Chiffre d'affaires journalier (somme des lignes : quantité × prix unitaire).</p>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <span class="fw-semibold"><i class="bi bi-pie-chart me-2 text-primary" aria-hidden="true"></i>Valeur du stock par catégorie</span>
            </div>
            <div class="card-body">
                <div class="ph-chart-container" style="height: 280px;">
                    <canvas id="stockChart" aria-label="Répartition de la valeur du stock par catégorie" role="img"></canvas>
                </div>
                <p class="small text-muted mb-0 mt-2">Estimation : stock × prix de vente (8 principales catégories).</p>
            </div>
        </div>
    </div>
</div>

<h2 class="app-dash-section-title">Activité récente</h2>
<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm table-card app-activity-panel">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-arrow-left-right me-2 text-muted" aria-hidden="true"></i>Derniers mouvements de stock</span>
                <a class="btn btn-sm btn-outline-primary" asp-controller="StockMovements" asp-action="Index">Tout voir</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentMovements.Count == 0)
                {
                    <div class="app-empty-state app-empty-state--compact border-0 rounded-0 m-3" role="status">
                        <i class="bi bi-arrow-left-right" aria-hidden="true"></i>
                        <p class="app-empty-state-title mb-1">Aucun mouvement</p>
                        <p class="mb-0 small">Les entrées, sorties et ajustements s'afficheront ici.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Produit</th>
                                    <th>Lot</th>
                                    <th class="text-end">Qté</th>
                                    <th>Resp.</th>
                                    <th>Vte</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in Model.RecentMovements)
                                {
                                    <tr>
                                        <td class="text-nowrap small">@m.OccurredAt.ToString("g")</td>
                                        <td><span class="badge bg-secondary-subtle text-dark">@MovementLabel(m.Type)</span></td>
                                        <td>@m.ProductName</td>
                                        <td class="small">@m.LotLabel</td>
                                        <td class="text-end">
                                            @switch (m.Type)
                                            {
                                                case StockMovementType.Entree:
                                                    <span class="text-success">+@m.Quantity</span>
                                                    break;
                                                case StockMovementType.Sortie:
                                                    <span class="text-danger">-@m.Quantity</span>
                                                    break;
                                                default:
                                                    <span>@(m.Quantity > 0 ? "+" : "")@m.Quantity</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="small text-muted">@m.ResponsibleDisplay</td>
                                        <td class="small text-nowrap">
                                            @if (m.SaleId is int sid)
                                            {
                                                <a asp-controller="Sales" asp-action="Details" asp-route-id="@sid">#@sid</a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm table-card app-activity-panel">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-receipt me-2 text-muted" aria-hidden="true"></i>Dernières ventes</span>
                <a class="btn btn-sm btn-outline-primary" asp-controller="Sales" asp-action="Index">Tout voir</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentSales.Count == 0)
                {
                    <div class="app-empty-state app-empty-state--compact border-0 rounded-0 m-3" role="status">
                        <i class="bi bi-receipt" aria-hidden="true"></i>
                        <p class="app-empty-state-title mb-1">Aucune vente</p>
                        <p class="mb-0 small">Les dernières ventes validées apparaîtront ici.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Date</th>
                                    <th class="text-end">Lignes</th>
                                    <th class="text-end">Total</th>
                                    <th>Enreg.</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.RecentSales)
                                {
                                    <tr>
                                        <td>@s.Id</td>
                                        <td class="text-nowrap small">@s.SoldAt.ToString("g")</td>
                                        <td class="text-end">@s.LineCount</td>
                                        <td class="text-end fw-medium">@s.Total.ToString("0.00") €</td>
                                        <td class="small text-muted">@s.RecordedByDisplay</td>
                                        <td class="text-end"><a asp-controller="Sales" asp-action="Details" asp-route-id="@s.Id">Détail</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (!window.Chart) return;

        const salesData = @Html.Raw(ViewBag.SalesChartData ?? "[]");
        const stockData = @Html.Raw(ViewBag.StockChartData ?? "[]");

        const salesCanvas = document.getElementById('salesChart');
        if (salesCanvas && salesData.length > 0) {
          new Chart(salesCanvas, {
            type: 'line',
            data: {
              labels: salesData.map(d => d.date),
              datasets: [{
                label: 'Ventes',
                data: salesData.map(d => d.amount),
                borderColor: '#2563EB',
                backgroundColor: 'rgba(37, 99, 235, 0.08)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointRadius: 3
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  ticks: {
                    callback: function (value) { return value + ' €'; }
                  }
                }
              }
            }
          });
        }

        const stockCanvas = document.getElementById('stockChart');
        if (stockCanvas && stockData.length > 0) {
          new Chart(stockCanvas, {
            type: 'doughnut',
            data: {
              labels: stockData.map(d => d.category),
              datasets: [{
                data: stockData.map(d => d.value),
                backgroundColor: [
                  '#2563EB',
                  '#10B981',
                  '#F59E0B',
                  '#EF4444',
                  '#8B5CF6',
                  '#06B6D4',
                  '#EC4899',
                  '#64748B'
                ]
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              cutout: '65%',
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: { boxWidth: 12, font: { size: 11 } }
                }
              }
            }
          });
        }
      });
    </script>
}
