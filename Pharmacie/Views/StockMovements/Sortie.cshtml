@model StockSortieViewModel
@{
    ViewData["Title"] = "Sortie de stock";
}

<div class="page-header">
    <h1 class="page-title">Sortie de stock</h1>
    <p class="page-lead mb-0">Retire des unités d’un lot existant et met à jour le stock du produit.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-box-arrow-up text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Sortie</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Sortie">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="BatchId" class="form-label"></label>
                        <select asp-for="BatchId" class="form-select" asp-items="@((SelectList)ViewData["BatchId"]!)">
                            <option value="">— Choisir un lot —</option>
                        </select>
                        <span asp-validation-for="BatchId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Reason" class="form-label"></label>
                        <input asp-for="Reason" class="form-control" placeholder="ex. Vente, casse…" />
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 pt-2 border-top">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1" aria-hidden="true"></i>Enregistrer la sortie</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
