@model StockMovementIndexPageViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using Pharmacie.Services
@{
    ViewData["Title"] = "Mouvements de stock";
    var userLabels = ViewBag.UserLabels as Dictionary<string, string> ?? new Dictionary<string, string>();
    var typeList = ViewData["FilterType"] as SelectList;
    var userList = ViewData["FilterUserId"] as IEnumerable<SelectListItem>;
}

<div class="page-header">
    <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-lg-between gap-3">
        <div>
            <h1 class="page-title">Mouvements de stock</h1>
            <p class="page-lead mb-0">Entrées, sorties et ajustements. <strong>Responsable</strong> : utilisateur connecté lors de l’enregistrement.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <a class="btn btn-primary" asp-controller="Batches" asp-action="Create"><i class="bi bi-box-arrow-in-down me-1" aria-hidden="true"></i>Entrée (lot)</a>
            <a class="btn btn-outline-primary" asp-action="Sortie"><i class="bi bi-box-arrow-up me-1" aria-hidden="true"></i>Sortie</a>
            <a class="btn btn-outline-secondary" asp-action="Ajustement"><i class="bi bi-sliders me-1" aria-hidden="true"></i>Ajustement</a>
            <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index"><i class="bi bi-layers me-1" aria-hidden="true"></i>Lots</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3">Filtres</h2>
        <p class="small text-muted mb-3">
            <strong>Produit</strong> : mouvements de ce produit. <strong>Type</strong> : entrée, sortie ou ajustement.
            <strong>Période</strong> : sur la date du mouvement (début de journée à fin de journée incluses pour les dates choisies).
            <strong>Responsable</strong> : filtre sur l’utilisateur enregistré sur le mouvement (comptes ayant déjà généré un mouvement).
        </p>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-6 col-lg-2">
                <label class="form-label small mb-0" for="ProductId">Produit</label>
                <select name="ProductId" id="ProductId" class="form-select form-select-sm">
                    @if ((Model.Filter.ProductId ?? 0) > 0)
                    {
                        <option value="">Tous</option>
                    }
                    else
                    {
                        <option value="" selected>Tous</option>
                    }
                    @foreach (var p in Model.ProductLookup)
                    {
                        if (Model.Filter.ProductId == p.Id)
                        {
                            <option value="@p.Id" selected>@p.CommercialName</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.CommercialName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 col-lg-2">
                <label class="form-label small mb-0" for="Type">Type</label>
                @if (typeList != null)
                {
                    @Html.DropDownList("Type", typeList, new { @class = "form-select form-select-sm", id = "Type" })
                }
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="From">Du</label>
                <input type="date" name="From" id="From" value="@(Model.Filter.From?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="To">Au</label>
                <input type="date" name="To" id="To" value="@(Model.Filter.To?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="UserId">Responsable</label>
                @if (userList != null)
                {
                    @Html.DropDownList("UserId", userList, "Tous", new { @class = "form-select form-select-sm", id = "UserId" })
                }
            </div>
            <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 pt-1 pt-lg-0">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
            </div>
        </form>
    </div>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
        <table class="table table-striped table-sm mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Produit</th>
                    <th>Lot</th>
                    <th>Impact</th>
                    <th>Responsable</th>
                    <th>Vente</th>
                    <th>Motif</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Movements)
                {
                    <tr>
                        <td class="text-nowrap small">@item.OccurredAt.ToString("g")</td>
                        <td>@(item.Type switch
                        {
                            StockMovementType.Entree => "Entrée",
                            StockMovementType.Sortie => "Sortie",
                            StockMovementType.Ajustement => "Ajustement",
                            _ => item.Type.ToString()
                        })</td>
                        <td>@item.Product?.CommercialName</td>
                        <td class="small">@item.Batch?.LotNumber</td>
                        <td>
                            @switch (item.Type)
                            {
                                case StockMovementType.Entree:
                                    <span class="text-success">+@item.Quantity</span>
                                    break;
                                case StockMovementType.Sortie:
                                    <span class="text-danger">-@item.Quantity</span>
                                    break;
                                default:
                                    <span>@(item.Quantity > 0 ? "+" : "")@item.Quantity</span>
                                    break;
                            }
                        </td>
                        <td class="small">@UserDisplayResolver.Resolve(userLabels, item.UserId)</td>
                        <td class="small text-nowrap">
                            @if (item.SaleId is int saleId)
                            {
                                <a asp-controller="Sales" asp-action="Details" asp-route-id="@saleId">#@saleId</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="small text-muted">@item.Reason</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Movements.Count > 0)
    {
        <div class="table-card-caption">@Model.Movements.Count mouvement(s) listé(s).</div>
    }
</div>
@if (Model.Movements.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-arrow-left-right" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun mouvement</p>
        <p class="mb-0 small">Aucun résultat pour ces critères.</p>
    </div>
}
