@model ProductIndexPageViewModel
@{
    ViewData["Title"] = "Produits";
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Produits</h1>
            <p class="page-lead mb-0">La quantité en stock suit les <a asp-controller="Batches" asp-action="Index">lots</a> et les <a asp-controller="StockMovements" asp-action="Index">mouvements</a>.</p>
        </div>
        <div class="flex-shrink-0">
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau produit</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3">Filtres</h2>
        <p class="small text-muted mb-3">
            <strong>Nom / générique</strong> : recherche partielle (sans respect de la casse côté base). <strong>Catégorie</strong> et <strong>fournisseur</strong> : liste déroulante exacte.
            <strong>Stock</strong> : « Faible » = produits <em>actifs</em> avec 0 &lt; quantité ≤ seuil d’alerte ; « Rupture » = actifs à quantité 0.
            <strong>État</strong> : actif ou inactif dans le catalogue.
        </p>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="Q">Nom ou générique</label>
                <input type="search" name="Q" id="Q" value="@Model.Filter.Q" class="form-control form-control-sm" autocomplete="off" />
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="CategoryId">Catégorie</label>
                <select name="CategoryId" id="CategoryId" class="form-select form-select-sm">
                    @if ((Model.Filter.CategoryId ?? 0) > 0)
                    {
                        <option value="">Toutes</option>
                    }
                    else
                    {
                        <option value="" selected>Toutes</option>
                    }
                    @foreach (var c in Model.CategoryLookup)
                    {
                        if (Model.Filter.CategoryId == c.Id)
                        {
                            <option value="@c.Id" selected>@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="SupplierId">Fournisseur</label>
                <select name="SupplierId" id="SupplierId" class="form-select form-select-sm">
                    @if ((Model.Filter.SupplierId ?? 0) > 0)
                    {
                        <option value="">Tous</option>
                    }
                    else
                    {
                        <option value="" selected>Tous</option>
                    }
                    @foreach (var s in Model.SupplierLookup)
                    {
                        if (Model.Filter.SupplierId == s.Id)
                        {
                            <option value="@s.Id" selected>@s.Name</option>
                        }
                        else
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="Stock">Stock</label>
                <select name="Stock" id="Stock" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.Stock))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (Model.Filter.Stock == "low")
                    {
                        <option value="low" selected>Faible (actifs)</option>
                    }
                    else
                    {
                        <option value="low">Faible (actifs)</option>
                    }
                    @if (Model.Filter.Stock == "out")
                    {
                        <option value="out" selected>Rupture (actifs)</option>
                    }
                    else
                    {
                        <option value="out">Rupture (actifs)</option>
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="Active">État catalogue</label>
                <select name="Active" id="Active" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.Active))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (Model.Filter.Active == "1")
                    {
                        <option value="1" selected>Actifs</option>
                    }
                    else
                    {
                        <option value="1">Actifs</option>
                    }
                    @if (Model.Filter.Active == "0")
                    {
                        <option value="0" selected>Inactifs</option>
                    }
                    else
                    {
                        <option value="0">Inactifs</option>
                    }
                </select>
            </div>
            <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 pt-1 pt-lg-0">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
                <a class="btn btn-outline-primary btn-sm" asp-action="IndexCsv"
                   asp-route-Q="@Model.Filter.Q"
                   asp-route-CategoryId="@Model.Filter.CategoryId"
                   asp-route-SupplierId="@Model.Filter.SupplierId"
                   asp-route-Stock="@Model.Filter.Stock"
                   asp-route-Active="@Model.Filter.Active"
                   title="Mêmes filtres que le formulaire">
                    <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
                </a>
            </div>
        </form>
    </div>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Nom commercial</th>
                    <th>Catégorie</th>
                    <th>Fournisseur</th>
                    <th>Prix de vente</th>
                    <th>Quantité en stock</th>
                    <th>Actif</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>@Html.DisplayFor(m => item.CommercialName)</td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Supplier?.Name</td>
                        <td>@Html.DisplayFor(m => item.SalePrice)</td>
                        <td>@Html.DisplayFor(m => item.StockQuantity)</td>
                        <td>@(item.IsActive ? "Oui" : "Non")</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary py-0" asp-action="Details" asp-route-id="@item.Id">Détails</a>
                            <a class="btn btn-sm btn-outline-primary py-0" asp-action="Edit" asp-route-id="@item.Id">Modifier</a>
                            <a class="btn btn-sm btn-outline-danger py-0" asp-action="Delete" asp-route-id="@item.Id">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Products.Count > 0)
    {
        <div class="table-card-caption">@Model.Products.Count produit(s) listé(s).</div>
    }
</div>
@if (Model.Products.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-inbox" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun produit</p>
        <p class="mb-0 small">Aucun résultat pour ces critères, ou catalogue vide.</p>
        <a class="btn btn-primary btn-sm mt-3" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau produit</a>
    </div>
}
