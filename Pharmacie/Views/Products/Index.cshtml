@model ProductIndexPageViewModel
@{
    ViewData["Title"] = "Produits";

    string ProductTypeBadgeClass(ProductType type) => type switch
    {
        ProductType.Medicament => "text-bg-primary",
        _ => "text-bg-secondary"
    };

    string ProductTypeLabel(ProductType type) => type switch
    {
        ProductType.Medicament => "Médicament",
        ProductType.Parapharmacie => "Parapharmacie",
        _ => "Inconnu"
    };
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3">
        <div>
            <h1 class="page-title">Produits</h1>
            <p class="page-lead mb-0">La quantité en stock suit les <a asp-controller="Batches" asp-action="Index">lots</a> et les <a asp-controller="StockMovements" asp-action="Index">mouvements</a>.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            @if (User.IsInRole(AppRoles.Administrateur) || User.IsInRole(AppRoles.Pharmacien))
            {
                <a asp-action="Classify" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-tags"></i> Classifier les produits
                </a>
            }
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau produit</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtres</h2>
        <p class="small text-muted mb-3">
            <strong>Nom / générique</strong> : recherche partielle (sans respect de la casse côté base). <strong>Catégorie</strong> et <strong>fournisseur</strong> : liste déroulante exacte.
            <strong>Stock</strong> : « Faible » = produits <em>actifs</em> avec 0 &lt; quantité ≤ seuil d'alerte ; « Rupture » = actifs à quantité 0.
            <strong>État</strong> : actif ou inactif dans le catalogue.
        </p>
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label class="form-label small mb-0" for="Q">Nom ou générique</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                    <input type="search" name="Q" id="Q" value="@Model.Filter.Q" class="form-control" placeholder="Rechercher…" autocomplete="off" />
                </div>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="CategoryId">Catégorie</label>
                <select name="CategoryId" id="CategoryId" class="form-select form-select-sm">
                    @if ((Model.Filter.CategoryId ?? 0) > 0)
                    {
                        <option value="">Toutes</option>
                    }
                    else
                    {
                        <option value="" selected>Toutes</option>
                    }
                    @foreach (var c in Model.CategoryLookup)
                    {
                        if (Model.Filter.CategoryId == c.Id)
                        {
                            <option value="@c.Id" selected>@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="SupplierId">Fournisseur</label>
                <select name="SupplierId" id="SupplierId" class="form-select form-select-sm">
                    @if ((Model.Filter.SupplierId ?? 0) > 0)
                    {
                        <option value="">Tous</option>
                    }
                    else
                    {
                        <option value="" selected>Tous</option>
                    }
                    @foreach (var s in Model.SupplierLookup)
                    {
                        if (Model.Filter.SupplierId == s.Id)
                        {
                            <option value="@s.Id" selected>@s.Name</option>
                        }
                        else
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="Stock">Stock</label>
                <select name="Stock" id="Stock" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.Stock))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (Model.Filter.Stock == "low")
                    {
                        <option value="low" selected>Faible (actifs)</option>
                    }
                    else
                    {
                        <option value="low">Faible (actifs)</option>
                    }
                    @if (Model.Filter.Stock == "out")
                    {
                        <option value="out" selected>Rupture (actifs)</option>
                    }
                    else
                    {
                        <option value="out">Rupture (actifs)</option>
                    }
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label small mb-0" for="Active">État catalogue</label>
                <select name="Active" id="Active" class="form-select form-select-sm">
                    @if (string.IsNullOrEmpty(Model.Filter.Active))
                    {
                        <option value="" selected>Tous</option>
                    }
                    else
                    {
                        <option value="">Tous</option>
                    }
                    @if (Model.Filter.Active == "1")
                    {
                        <option value="1" selected>Actifs</option>
                    }
                    else
                    {
                        <option value="1">Actifs</option>
                    }
                    @if (Model.Filter.Active == "0")
                    {
                        <option value="0" selected>Inactifs</option>
                    }
                    else
                    {
                        <option value="0">Inactifs</option>
                    }
                </select>
            </div>
            <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 pt-1 pt-lg-0">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtrer</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Réinitialiser</a>
                <a class="btn btn-outline-primary btn-sm" asp-action="IndexCsv"
                   asp-route-Q="@Model.Filter.Q"
                   asp-route-CategoryId="@Model.Filter.CategoryId"
                   asp-route-SupplierId="@Model.Filter.SupplierId"
                   asp-route-Stock="@Model.Filter.Stock"
                   asp-route-Active="@Model.Filter.Active"
                   title="Mêmes filtres que le formulaire">
                    <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm table-card mb-3">
    <div class="card-header bg-white border-bottom py-3">
        <span class="fw-semibold"><i class="bi bi-capsule me-2 text-primary" aria-hidden="true"></i>Catalogue produits</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>CIP</th>
                    <th>Nom commercial</th>
                    <th>Type</th>
                    <th>Catégorie</th>
                    <th>Fournisseur</th>
                    <th class="text-end">Prix vente</th>
                    <th class="text-end">Stock</th>
                    <th>État</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    var lowStock = item.IsActive && item.StockQuantity < item.AlertThreshold;
                    var outOfStock = item.StockQuantity == 0;
                    <tr>
                        <td class="font-monospace small text-muted">@(string.IsNullOrWhiteSpace(item.Cip) ? "—" : item.Cip)</td>
                        <td>
                            <div class="fw-medium">@Html.DisplayFor(m => item.CommercialName)</div>
                            @if (!string.IsNullOrWhiteSpace(item.GenericName))
                            {
                                <div class="small text-muted">@item.GenericName</div>
                            }
                        </td>
                        <td>
                            @if (item.ProductType == ProductType.Parapharmacie)
                            {
                                <span class="badge text-white" style="background-color:#8B5CF6">@ProductTypeLabel(item.ProductType)</span>
                            }
                            else
                            {
                                <span class="badge @ProductTypeBadgeClass(item.ProductType)">@ProductTypeLabel(item.ProductType)</span>
                            }
                        </td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Supplier?.Name</td>
                        <td class="text-end text-nowrap">@item.SalePrice.ToString("0.00") €</td>
                        <td class="text-end">
                            @if (outOfStock)
                            {
                                <span class="badge text-bg-danger" title="Rupture de stock"><i class="bi bi-x-circle me-1" aria-hidden="true"></i>@item.StockQuantity</span>
                            }
                            else if (lowStock)
                            {
                                <span class="badge text-bg-danger" title="Sous le seuil (@item.AlertThreshold)"><i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>@item.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success-subtle text-success-emphasis border border-success-subtle">@item.StockQuantity</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge text-bg-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Inactif</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id" title="Détails" data-bs-toggle="tooltip">
                                <i class="bi bi-eye" aria-hidden="true"></i><span class="d-none d-xl-inline ms-1">Détails</span>
                            </a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id" title="Modifier" data-bs-toggle="tooltip">
                                <i class="bi bi-pencil" aria-hidden="true"></i><span class="d-none d-xl-inline ms-1">Modifier</span>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Supprimer" data-bs-toggle="tooltip">
                                <i class="bi bi-trash" aria-hidden="true"></i><span class="d-none d-xl-inline ms-1">Supprimer</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Products.Count > 0)
    {
        <div class="table-card-caption d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 px-3 py-2">
            <span>@Model.Products.Count produit(s) sur @(ViewBag.TotalCount ?? 0) · page @(ViewBag.CurrentPage ?? 1)/@(ViewBag.TotalPages ?? 1)</span>
            @{
                var paginationRoutes = new Dictionary<string, string>();
                if (!string.IsNullOrWhiteSpace(Model.Filter.Q))
                    paginationRoutes["Q"] = Model.Filter.Q;
                if (Model.Filter.CategoryId is > 0)
                    paginationRoutes["CategoryId"] = Model.Filter.CategoryId.Value.ToString();
                if (Model.Filter.SupplierId is > 0)
                    paginationRoutes["SupplierId"] = Model.Filter.SupplierId.Value.ToString();
                if (!string.IsNullOrWhiteSpace(Model.Filter.Stock))
                    paginationRoutes["Stock"] = Model.Filter.Stock;
                if (!string.IsNullOrWhiteSpace(Model.Filter.Active))
                    paginationRoutes["Active"] = Model.Filter.Active;
                ViewBag.PaginationRoutes = paginationRoutes;
            }
            <partial name="_Pagination" />
        </div>
    }
</div>
@if (Model.Products.Count == 0)
{
    <div class="app-empty-state my-3" role="status">
        <i class="bi bi-inbox" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun produit</p>
        <p class="mb-0 small">Aucun résultat pour ces critères, ou catalogue vide.</p>
        <a class="btn btn-primary btn-sm mt-3" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau produit</a>
    </div>
}

@section Scripts {
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
          new bootstrap.Tooltip(el);
        });
      });
    </script>
}
