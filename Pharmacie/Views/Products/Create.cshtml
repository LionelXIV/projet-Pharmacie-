@model Product
@{
    ViewData["Title"] = "Nouveau produit";
}

<div class="page-header">
    <h1 class="page-title">Nouveau produit</h1>
    <p class="page-lead mb-0">Créez d’abord au moins une <a asp-controller="Categories" asp-action="Index">catégorie</a> et un <a asp-controller="Suppliers" asp-action="Index">fournisseur</a>.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-capsule text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Fiche produit</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <form asp-action="Create">
                    <partial name="_ProductForm" model="Model" />
                    <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1" aria-hidden="true"></i>Enregistrer</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
