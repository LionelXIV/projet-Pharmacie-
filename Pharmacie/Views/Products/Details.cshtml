@model Product
@{
    ViewData["Title"] = "Détails produit";
}

<div class="page-header">
    <h1 class="page-title">@Model.CommercialName</h1>
    <nav class="app-breadcrumb mt-2 mb-0 d-inline-block" aria-label="Navigation">
        <a asp-action="Index">Produits</a>
    </nav>
</div>

<div class="row">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-capsule text-primary fs-5" aria-hidden="true"></i>
                <span class="fw-semibold">Fiche</span>
            </div>
            <div class="card-body p-3 p-md-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CommercialName)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.CommercialName)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.GenericName)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.GenericName)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Category)</dt>
                    <dd class="col-sm-9">@Model.Category?.Name</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Form)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Form)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Dosage)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Dosage)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Supplier)</dt>
                    <dd class="col-sm-9">@Model.Supplier?.Name</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.PurchasePrice)</dt>
                    <dd class="col-sm-9">@ReportCsvFormatter.FormatFcfa(Model.PurchasePrice)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SalePrice)</dt>
                    <dd class="col-sm-9">@ReportCsvFormatter.FormatFcfa(Model.SalePrice)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.StockQuantity)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.StockQuantity)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.AlertThreshold)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.AlertThreshold)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Location)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Location)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsActive)</dt>
                    <dd class="col-sm-9">@(Model.IsActive ? "Oui" : "Non")</dd>
                </dl>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil me-1" aria-hidden="true"></i>Modifier</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Retour à la liste</a>
        </div>
    </div>
</div>
