@model Product
@{
    ViewData["Title"] = "Supprimer le produit";
}

<div class="page-header">
    <h1 class="page-title">Supprimer le produit</h1>
    <p class="page-lead mb-0 text-danger">Cette action supprime définitivement la fiche produit.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3 p-md-4">
                <dl class="row mb-4">
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CommercialName)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.CommercialName)</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Category)</dt>
                    <dd class="col-sm-9">@Model.Category?.Name</dd>
                </dl>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1" aria-hidden="true"></i>Supprimer</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
