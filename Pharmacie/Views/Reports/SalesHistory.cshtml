@model IReadOnlyList<ReportSaleHistoryRowViewModel>
@{
    ViewData["Title"] = "Rapport — Historique ventes";
    var limit = (int)(ViewBag.RowLimit ?? 500);
}

<nav class="app-breadcrumb mb-3" aria-label="Fil d’Ariane">
    <ol class="breadcrumb mb-0 py-1">
        <li class="breadcrumb-item"><a asp-action="Index">Rapports</a></li>
        <li class="breadcrumb-item active" aria-current="page">Historique ventes</li>
    </ol>
</nav>

<div class="page-header">
    <h1 class="page-title">Historique des ventes</h1>
    <p class="page-lead mb-0">Les <strong>@limit</strong> ventes les plus récentes.</p>
</div>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="SalesHistoryCsv" role="button">
        <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
    </a>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
    <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th class="text-end">N° vente</th>
                <th class="text-end">Lignes</th>
                <th class="text-end">Total</th>
                <th>Paiement</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="text-nowrap">@r.SoldAt.ToString("g")</td>
                    <td class="text-end">@r.SaleId</td>
                    <td class="text-end">@r.LineCount</td>
                    <td class="text-end fw-medium">@ReportCsvFormatter.FormatFcfa(r.Total)</td>
                    <td>
                        <span class="badge @PaymentMethodDisplay.BadgeCssClass(r.PaymentMethod)">
                            @PaymentMethodDisplay.GetName(r.PaymentMethod)
                        </span>
                    </td>
                    <td class="text-end"><a asp-controller="Sales" asp-action="Details" asp-route-id="@r.SaleId">Détail</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="table-card-caption">@Model.Count vente(s) affichée(s) (plafond @limit).</div>
    }
</div>
@if (Model.Count == 0)
{
    <div class="app-empty-state app-empty-state--compact my-3" role="status">
        <i class="bi bi-receipt" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucune vente</p>
        <p class="mb-0 small">Aucun enregistrement dans la période affichée.</p>
    </div>
}
