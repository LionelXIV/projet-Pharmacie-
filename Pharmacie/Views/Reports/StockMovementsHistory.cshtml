@model IReadOnlyList<ReportMovementHistoryRowViewModel>
@using Pharmacie.Models
@{
    ViewData["Title"] = "Rapport — Historique mouvements";
    var limit = (int)(ViewBag.RowLimit ?? 1000);
    string TypeLabel(StockMovementType t) => t switch
    {
        StockMovementType.Entree => "Entrée",
        StockMovementType.Sortie => "Sortie",
        StockMovementType.Ajustement => "Ajustement",
        _ => t.ToString()
    };
}

<nav class="app-breadcrumb mb-3" aria-label="Fil d’Ariane">
    <ol class="breadcrumb mb-0 py-1">
        <li class="breadcrumb-item"><a asp-action="Index">Rapports</a></li>
        <li class="breadcrumb-item active" aria-current="page">Historique mouvements</li>
    </ol>
</nav>

<div class="page-header">
    <h1 class="page-title">Historique des mouvements de stock</h1>
    <p class="page-lead mb-0">Les <strong>@limit</strong> mouvements les plus récents. <strong>Responsable</strong> : utilisateur connecté lors de l’enregistrement.</p>
</div>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="StockMovementsHistoryCsv" role="button">
        <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
    </a>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
    <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Produit</th>
                <th>Type</th>
                <th class="text-end">Quantité</th>
                <th>Responsable</th>
                <th>Vente</th>
                <th>Motif</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="text-nowrap small">@r.OccurredAt.ToString("g")</td>
                    <td>@r.ProductName</td>
                    <td><span class="badge bg-secondary-subtle text-dark">@TypeLabel(r.Type)</span></td>
                    <td class="text-end">
                        @switch (r.Type)
                        {
                            case StockMovementType.Entree:
                                <span class="text-success">+@r.Quantity</span>
                                break;
                            case StockMovementType.Sortie:
                                <span class="text-danger">-@r.Quantity</span>
                                break;
                            default:
                                <span>@(r.Quantity > 0 ? "+" : "")@r.Quantity</span>
                                break;
                        }
                    </td>
                    <td class="small">@r.UserOrResponsible</td>
                    <td class="small text-nowrap">
                        @if (r.SaleId is int sid)
                        {
                            <a asp-controller="Sales" asp-action="Details" asp-route-id="@sid">#@sid</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="small text-muted">@(r.Reason ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="table-card-caption">@Model.Count mouvement(s) affiché(s) (plafond @limit).</div>
    }
</div>
@if (Model.Count == 0)
{
    <div class="app-empty-state app-empty-state--compact my-3" role="status">
        <i class="bi bi-arrow-left-right" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun mouvement</p>
        <p class="mb-0 small">Aucun mouvement dans la période affichée.</p>
    </div>
}
