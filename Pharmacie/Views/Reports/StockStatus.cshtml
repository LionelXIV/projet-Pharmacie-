@model IReadOnlyList<ReportStockStatusRowViewModel>
@{
    ViewData["Title"] = "Rapport — État du stock";
}

<nav class="app-breadcrumb mb-3" aria-label="Fil d’Ariane">
    <ol class="breadcrumb mb-0 py-1">
        <li class="breadcrumb-item"><a asp-action="Index">Rapports</a></li>
        <li class="breadcrumb-item active" aria-current="page">État du stock</li>
    </ol>
</nav>

<div class="page-header">
    <h1 class="page-title">État du stock</h1>
    <p class="page-lead mb-0">Produits <strong>actifs</strong> uniquement. Statut : <span class="badge bg-success">Normal</span> stock &gt; seuil, <span class="badge bg-warning text-dark">Stock faible</span> ≤ seuil, <span class="badge bg-danger">Rupture</span> = 0.</p>
</div>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="StockStatusCsv" role="button">
        <i class="bi bi-download me-1" aria-hidden="true"></i>Exporter CSV
    </a>
</div>

<div class="table-card mb-3">
    <div class="table-responsive">
    <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Produit</th>
                <th>Catégorie</th>
                <th>Fournisseur</th>
                <th class="text-end">Stock</th>
                <th class="text-end">Seuil</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.ProductName</td>
                    <td>@r.CategoryName</td>
                    <td>@r.SupplierName</td>
                    <td class="text-end">@r.StockQuantity</td>
                    <td class="text-end">@r.AlertThreshold</td>
                    <td><span class="badge @r.StatusBadgeClass">@r.StatusLabel</span></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="table-card-caption">@Model.Count produit(s) actif(s) listé(s).</div>
    }
</div>
@if (Model.Count == 0)
{
    <div class="app-empty-state app-empty-state--compact mt-3" role="status">
        <i class="bi bi-clipboard-data" aria-hidden="true"></i>
        <p class="app-empty-state-title mb-1">Aucun produit actif</p>
        <p class="mb-0 small">Activez des produits ou créez-en dans le catalogue.</p>
    </div>
}
