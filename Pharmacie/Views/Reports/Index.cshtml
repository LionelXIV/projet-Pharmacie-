@{
    ViewData["Title"] = "Rapports";
}

<div class="page-header">
    <h1 class="page-title">Rapports</h1>
    <p class="page-lead mb-0">Synthèses sur le stock, la péremption, les ventes et les mouvements.</p>
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 report-hub-card">
            <div class="card-body">
                <h2 class="h5 card-title"><i class="bi bi-clipboard-data" aria-hidden="true"></i>État du stock</h2>
                <p class="card-text small text-muted">Quantités, seuils et statut par produit actif.</p>
                <a class="btn btn-outline-primary stretched-link" asp-action="StockStatus">Ouvrir</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 report-hub-card">
            <div class="card-body">
                <h2 class="h5 card-title"><i class="bi bi-hourglass-split" aria-hidden="true"></i>Proches de l’expiration</h2>
                <p class="card-text small text-muted">Lots encore valides dans la fenêtre d’alerte (90 jours).</p>
                <a class="btn btn-outline-primary stretched-link" asp-action="NearExpiration">Ouvrir</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 report-hub-card">
            <div class="card-body">
                <h2 class="h5 card-title"><i class="bi bi-calendar-x" aria-hidden="true"></i>Produits expirés</h2>
                <p class="card-text small text-muted">Lots encore en stock après date de péremption.</p>
                <a class="btn btn-outline-primary stretched-link" asp-action="ExpiredProducts">Ouvrir</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 report-hub-card">
            <div class="card-body">
                <h2 class="h5 card-title"><i class="bi bi-receipt" aria-hidden="true"></i>Historique des ventes</h2>
                <p class="card-text small text-muted">Dernières ventes enregistrées.</p>
                <a class="btn btn-outline-primary stretched-link" asp-action="SalesHistory">Ouvrir</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 report-hub-card">
            <div class="card-body">
                <h2 class="h5 card-title"><i class="bi bi-arrow-left-right" aria-hidden="true"></i>Historique des mouvements</h2>
                <p class="card-text small text-muted">Derniers mouvements et responsable.</p>
                <a class="btn btn-outline-primary stretched-link" asp-action="StockMovementsHistory">Ouvrir</a>
            </div>
        </div>
    </div>
</div>
